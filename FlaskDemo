from doctest import debug

from flask import Flask, render_template, request, jsonify
from langchain_community.llms import Ollama
from langchain.schema import SystemMessage,HumanMessage, AIMessage

app = Flask(__name__)

# Initialize LLaMA3 model (Ollama must be running locally)
llm = Ollama(model="llama3")

# Store conversation history in memory
messages = [ SystemMessage(content="You are an assistant, generate a response only two lines.")]

@app.route("/")
def index():
    return render_template("index.html")

@app.route("/process", methods=["POST"])
def process():
    try:
        data = request.get_json()
        user_input = data.get("user_input", "")

        if not isinstance(user_input, str):
            return jsonify({"response": "Invalid input type"}), 400

        # Append the user's message to history
        messages.append(HumanMessage(content=user_input))

        # Pass the full conversation history to the LLM
        llm_response = llm.invoke(messages)

        # Append AI's response to history
        messages.append(AIMessage(content=llm_response))

        return jsonify({"response": llm_response})
    except Exception as e:
        return jsonify({"response": f"Error: {str(e)}"}), 500

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=9090,  debug=True)
